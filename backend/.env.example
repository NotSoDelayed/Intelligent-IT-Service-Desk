# Rename is not needed -- this file is read directly. Fill in real values below.

# Used to sign JWT auth tokens. Generate one with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-long-random-secret-string

# Token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# SQLite by default. Swap for postgres://... in production.
DATABASE_URL=sqlite:///./data/service_desk.db

# ---- AI (Gemini) ----
# Get a key from https://aistudio.google.com/apikey
# Paste it below. If left empty, the system automatically falls back to a
# deterministic rule-based classifier so the app still runs end-to-end.
GEMINI_API_KEY=

# Fast model used for ticket triage (category/priority/difficulty/routing).
# gemini-2.5-flash is the recommended default: fast + cheap + good enough
# for structured classification. Swap to gemini-2.5-pro if you want deeper
# reasoning at the cost of latency.
GEMINI_MODEL=gemini-2.5-flash

# ---- Default admin account, auto-created on first startup ----
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@12345
ADMIN_FULL_NAME=IT Admin
